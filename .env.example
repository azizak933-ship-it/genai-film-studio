# ── AI Providers (add any combination — agents fall back through the chain) ──────
GROQ_API_KEY=gsk_...          # Free: console.groq.com — 14,400 req/day
GOOGLE_API_KEY=AIza...        # Free: aistudio.google.com — Gemini 2.5 Flash
OPENROUTER_API_KEY=sk-or-...  # Free tier: openrouter.ai — 100+ models
ANTHROPIC_API_KEY=sk-ant-...  # Paid: console.anthropic.com — Claude (priority provider)

# ── Image Generation ─────────────────────────────────────────────────────────────
HF_TOKEN=hf_...               # Free: huggingface.co/settings/tokens — FLUX.1-schnell
STABILITY_API_KEY=sk-...      # Paid: platform.stability.ai — Stable Diffusion
REPLICATE_API_KEY=r8_...      # Paid: replicate.com

# ── Text-to-Speech ───────────────────────────────────────────────────────────────
OPENAI_TTS_KEY=sk-...         # Paid: platform.openai.com — TTS-1
ELEVENLABS_API_KEY=...        # Paid: elevenlabs.io — high-quality voices

# ── Web Search / Research ────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...       # Free tier: tavily.com — AI-optimized search
JINA_API_KEY=jina_...         # Free tier: jina.ai — works without key too

# ── Infrastructure ───────────────────────────────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434   # Default Ollama endpoint (local LLMs)
PORT=3000                            # Server port (default: 3000)
APP_TOKEN=your-secret-token          # Optional: password-protect the UI
